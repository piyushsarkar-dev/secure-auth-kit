      "updated": 1773663412582,
      "link": null,
      "locked": false,
      "text": "export const registerSchema = z.object({\n        name: z.string().min(2, { error: \"Name must be at least 2 characters\" }),\n        email: z.email({ error: \"Invalid email\" }),\n        password: z\n                .string()\n                .min(8, { error: \"Password must be at least 8 characters\" }),\n});\n",
      "fontSize": 22.30445132143464,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "export const registerSchema = z.object({\n        name: z.string().min(2, { error: \"Name must be at least 2 characters\" }),\n        email: z.email({ error: \"Invalid email\" }),\n        password: z\n                .string()\n                .min(8, { error: \"Password must be at least 8 characters\" }),\n});\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
